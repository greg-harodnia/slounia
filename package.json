{
	"name": "bel-dicttt",
	"version": "0.0.1",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.61.1",
		"vite": "^8.0.7",
		"vite-plugin-pwa": "^1.3.0",
		"vitest": "^4.1.8"
	},
	"private": true,
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
